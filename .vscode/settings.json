{
  "editor.formatOnSave": true,
  "editor.rulers": [100],
  "editor.defaultFormatter": null, // make formatting behavior more predictable
  "files.readonlyInclude": {
    "mise.lock": true,
    "bun.lock": true
  },

  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  // extended cSpell dictionary
  "cSpell.words": ["oxfmt", "tria"]
}
